# ─────────────────────────────────────────────────────────────────────────────
# JIRA — shared by Python CLI (JiraClient) and mcp-atlassian MCP server
# ─────────────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-jira.company.com   # Python JiraClient base URL
JIRA_URL=https://your-jira.company.com        # mcp-atlassian
JIRA_EMAIL=your.username                      # Python: used to build Basic auth header
JIRA_USERNAME=your.username                   # mcp-atlassian: Basic auth username
JIRA_API_TOKEN=your-raw-pat                   # Raw PAT — Python base64-encodes (email:token); mcp-atlassian uses directly
JIRA_SSL_VERIFY=false                         # Set to false for internal SSL certs; true for public instances

# ─────────────────────────────────────────────────────────────────────────────
# Confluence — shared by Python CLI (ConfluenceClient) and mcp-atlassian MCP server
# ─────────────────────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-confluence.company.com   # Python ConfluenceClient base URL
CONFLUENCE_URL=https://your-confluence.company.com        # mcp-atlassian
CONFLUENCE_EMAIL=your.username                            # Python
CONFLUENCE_USERNAME=your.username                         # mcp-atlassian: Basic auth username
CONFLUENCE_API_TOKEN=your-base64-encoded-userid-pat        # Python ConfluenceClient only — pre-encoded base64(userId:PAT), used as Bearer token
CONFLUENCE_PERSONAL_TOKEN=your-raw-pat                    # mcp-atlassian only — raw PAT, sent as Authorization: Bearer <token>
CONFLUENCE_SSL_VERIFY=false                               # Set to false for internal SSL certs

# ─────────────────────────────────────────────────────────────────────────────
# Figma (optional — only needed for Figma screenshot commands)
# ─────────────────────────────────────────────────────────────────────────────
FIGMA_API_TOKEN=your-figma-token
FIGMA_ACCESS_TOKEN=your-figma-token
