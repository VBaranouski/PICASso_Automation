<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Story Coverage Summary &mdash; {{ generated_date }}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: {{ branding.font_family }};
    background: #f4f6f8;
    color: {{ branding.text_color }};
    font-size: 13px;
    line-height: 1.5;
  }
  .page {
    max-width: 900px;
    margin: 32px auto;
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 2px 12px rgba(0,0,0,.10);
    overflow: hidden;
  }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, {{ branding.primary_color }} 0%, {{ branding.dark_color }} 100%);
    padding: 24px 32px;
    display: flex; align-items: center; gap: 16px;
  }
  .se-mark {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,255,255,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 800; color: #fff;
    border: 2px solid rgba(255,255,255,0.5); flex-shrink: 0;
  }
  .header h1 { font-size: 18px; font-weight: 700; color: #fff; }
  .header-sub { font-size: 11px; color: rgba(255,255,255,.8); margin-top: 3px; }

  /* STATS STRIP */
  .stats {
    display: flex;
    border-bottom: 1px solid #e0e0e0;
    background: #fafafa;
  }
  .stat {
    flex: 1; padding: 14px 20px;
    border-right: 1px solid #e0e0e0;
    text-align: center;
  }
  .stat:last-child { border-right: none; }
  .stat .val { font-size: 26px; font-weight: 700; color: {{ branding.dark_color }}; line-height: 1; }
  .stat .lbl { font-size: 11px; color: #777; margin-top: 3px; }
  .stat.highlight .val { color: {{ branding.dark_color }}; }

  /* SECTION TITLE */
  .section-title {
    padding: 18px 32px 8px;
    font-size: 14px; font-weight: 700;
    color: {{ branding.dark_color }};
    border-bottom: 2px solid {{ branding.primary_color }};
    margin-bottom: 0;
  }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  th {
    padding: 9px 14px;
    text-align: left;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.5px; text-transform: uppercase;
    color: #fff;
    background: {{ branding.dark_color }};
    border-bottom: 2px solid {{ branding.primary_color }};
  }
  td { padding: 9px 14px; border-bottom: 1px solid #eee; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background: {{ branding.row_alt_color }}; }
  tr:hover td { background: {{ branding.hover_color }}; }

  .col-rank  { width: 36px; text-align: center; }
  td.col-rank { color: #aaa; font-size: 11px; }
  .col-key   { width: 95px; white-space: nowrap; }
  .col-key a { color: #1565C0; text-decoration: none; font-weight: 600; }
  .col-key a:hover { text-decoration: underline; }
  .col-summary { }
  .col-total { width: 55px; text-align: center; }
  .col-sit   { width: 45px; text-align: center; }
  .col-uat   { width: 45px; text-align: center; }
  .col-prod  { width: 45px; text-align: center; }

  /* COUNT PILLS */
  .pill {
    display: inline-block;
    min-width: 22px; padding: 1px 7px;
    border-radius: 12px; font-size: 11px; font-weight: 700;
    text-align: center;
  }
  .pill-total { background: {{ branding.dark_color }}; color: #fff; }
  .pill-sit   { background: #DBEAFE; color: #1565C0; }
  .pill-uat   { background: #FEF3C7; color: #92400E; }
  .pill-prod  { background: #FFE4E6; color: #9F1239; }
  .pill-zero  { color: #ccc; font-weight: 400; }

  /* UNLINKED NOTE */
  .unlinked-note {
    padding: 10px 32px;
    font-size: 11.5px; color: #888;
    border-top: 1px solid #eee;
    background: #fafafa;
  }
  .unlinked-note strong { color: #555; }

  /* FOOTER */
  .footer {
    background: #f9f9f9; border-top: 1px solid #e0e0e0;
    padding: 12px 32px;
    display: flex; justify-content: space-between;
    font-size: 11px; color: #888;
  }
  .footer-logo { font-weight: 700; color: {{ branding.dark_color }}; }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header">
    <div class="se-mark">SE</div>
    <div>
      <h1>Story Coverage Summary</h1>
      <div class="header-sub">User Stories &amp; Features tested via reported defects &mdash; {{ generated_date }}</div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats">
    <div class="stat highlight">
      <div class="val">{{ stories | length }}</div>
      <div class="lbl">Stories / Features Covered</div>
    </div>
    <div class="stat">
      <div class="val">{{ total_defects }}</div>
      <div class="lbl">Total Defects</div>
    </div>
    <div class="stat">
      <div class="val" style="color:#1565C0">{{ total_sit }}</div>
      <div class="lbl">SIT Defects</div>
    </div>
    <div class="stat">
      <div class="val" style="color:#92400E">{{ total_uat }}</div>
      <div class="lbl">UAT Defects</div>
    </div>
    <div class="stat">
      <div class="val" style="color:#9F1239">{{ total_prod }}</div>
      <div class="lbl">Production Defects</div>
    </div>
  </div>

  <!-- TABLE -->
  <div class="section-title">Tested User Stories &amp; Features</div>
  {% if stories %}
  <table>
    <thead>
      <tr>
        <th class="col-rank">#</th>
        <th class="col-key">Story / Feature</th>
        <th class="col-summary">Summary</th>
        <th class="col-total">Total</th>
        <th class="col-sit">SIT</th>
        <th class="col-uat">UAT</th>
        <th class="col-prod">Prod</th>
      </tr>
    </thead>
    <tbody>
      {% for story in stories %}
      <tr>
        <td class="col-rank">{{ loop.index }}</td>
        <td class="col-key"><a href="#">{{ story.key }}</a></td>
        <td class="col-summary">{{ story.summary or '&mdash;' }}</td>
        <td class="col-total">
          <span class="pill pill-total">{{ story.total }}</span>
        </td>
        <td class="col-sit">
          {% if story.sit_defects | length > 0 %}
          <span class="pill pill-sit">{{ story.sit_defects | length }}</span>
          {% else %}<span class="pill-zero">0</span>{% endif %}
        </td>
        <td class="col-uat">
          {% if story.uat_defects | length > 0 %}
          <span class="pill pill-uat">{{ story.uat_defects | length }}</span>
          {% else %}<span class="pill-zero">0</span>{% endif %}
        </td>
        <td class="col-prod">
          {% if story.prod_defects | length > 0 %}
          <span class="pill pill-prod">{{ story.prod_defects | length }}</span>
          {% else %}<span class="pill-zero">0</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div style="padding:24px 32px;color:#aaa;font-style:italic;">No linked stories found in the fetched defects.</div>
  {% endif %}

  <!-- UNLINKED NOTE -->
  {% set unlinked_total = unlinked_sit + unlinked_uat + unlinked_prod %}
  {% if unlinked_total > 0 %}
  <div class="unlinked-note">
    <strong>{{ unlinked_total }} defect{{ 's' if unlinked_total != 1 else '' }}</strong>
    had no parent Story / Feature link and are not included above
    (SIT: {{ unlinked_sit }}, UAT: {{ unlinked_uat }}, Prod: {{ unlinked_prod }}).
  </div>
  {% endif %}

  <!-- FOOTER -->
  <div class="footer">
    <span class="footer-logo">Schneider Electric &mdash; SE-DevTools</span>
    <span>{{ stories | length }} stories &bull; {{ total_defects }} defects &bull; {{ generated_date }}</span>
  </div>

</div>
</body>
</html>
