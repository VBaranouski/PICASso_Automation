<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bug &amp; Defect Report &mdash; {{ generated_date }}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; background: #f2f2f2; color: #1a1a1a; padding: 32px 16px; }
  .card { max-width: 1100px; margin: 0 auto; background: #fff; border-radius: 4px; box-shadow: 0 2px 16px rgba(0,0,0,.10); overflow: hidden; border-top: 5px solid #3DCD58; }

  /* HEADER */
  .header { background: linear-gradient(135deg, #3DCD58 0%, #009530 100%); color: #fff; padding: 28px 32px 24px; }
  .header h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
  .header .meta { font-size: 13px; opacity: .9; }

  /* SUMMARY STRIP */
  .summary-strip { display: flex; border-bottom: 2px solid #e6e6e6; }
  .s-card { flex: 1; padding: 18px 24px; text-align: center; border-right: 1px solid #e6e6e6; }
  .s-card:last-child { border-right: none; }
  .s-count { font-size: 32px; font-weight: 700; line-height: 1.1; }
  .s-label { font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
  .s-card.sit  .s-count { color: #1565C0; }
  .s-card.uat  .s-count { color: #E65100; }
  .s-card.prod .s-count { color: #B71C1C; }

  /* SECTIONS */
  .section { padding: 24px 32px; border-bottom: 1px solid #e6e6e6; }
  .section:last-of-type { border-bottom: none; }
  .section-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .section-header h2 { font-size: 16px; font-weight: 700; }
  .section.sit  .section-header h2 { color: #1565C0; }
  .section.uat  .section-header h2 { color: #E65100; }
  .section.prod .section-header h2 { color: #B71C1C; }
  .sec-period { font-size: 11px; color: #888; border: 1px solid #ddd; padding: 2px 8px; border-radius: 3px; }
  .sec-count { margin-left: auto; font-size: 11px; font-weight: 700; padding: 2px 10px; border-radius: 3px; }
  .section.sit  .sec-count { background: #E3F2FD; color: #1565C0; }
  .section.uat  .sec-count { background: #FFF3E0; color: #E65100; }
  .section.prod .sec-count { background: #FFEBEE; color: #B71C1C; }
  .reporters-line { font-size: 12px; color: #666; margin-bottom: 14px; padding: 6px 12px; background: #fafafa; border: 1px solid #eee; border-radius: 3px; }
  .reporters-line strong { color: #333; }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead tr { background: #f5f5f5; }
  th { text-align: left; padding: 9px 12px; font-size: 11px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; color: #666; border-bottom: 2px solid #ddd; }
  tbody tr { border-bottom: 1px solid #eee; }
  tbody tr:hover { background: #fafafa; }
  td { padding: 9px 12px; vertical-align: top; }
  .col-num { width: 36px; text-align: center; }
  td.col-num { color: #aaa; font-size: 12px; }
  .col-key { width: 95px; white-space: nowrap; }
  .col-key a { color: #1565C0; text-decoration: none; font-weight: 600; font-size: 12px; }
  .col-key a:hover { text-decoration: underline; }
  .col-type { width: 80px; }
  .col-pri { width: 90px; }
  .col-status { width: 115px; }
  .col-reporter { width: 145px; }
  .col-date { width: 90px; white-space: nowrap; }
  td.col-date, td.col-type, td.col-reporter { color: #888; font-size: 12px; }

  /* BADGES */
  .badge { display: inline-block; padding: 2px 8px; font-size: 11px; font-weight: 600; border-radius: 3px; white-space: nowrap; }
  .badge-blocker  { background: #FFCDD2; color: #B71C1C; }
  .badge-critical { background: #FFCDD2; color: #C62828; }
  .badge-high     { background: #FFE0B2; color: #E65100; }
  .badge-medium   { background: #E3F2FD; color: #1565C0; }
  .badge-low      { background: #F5F5F5; color: #888; }

  /* STATUS */
  .status-pill { display: inline-flex; align-items: center; gap: 5px; padding: 2px 8px; font-size: 11px; font-weight: 600; border-radius: 3px; white-space: nowrap; }
  .status-pill .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .status-open   { background: #FFF8E1; color: #F57F17; }
  .status-open   .dot { background: #F57F17; }
  .status-inprog { background: #EDE7F6; color: #5E35B1; }
  .status-inprog .dot { background: #5E35B1; }
  .status-closed { background: #E8F5E9; color: #2E7D32; }
  .status-closed .dot { background: #2E7D32; }
  .status-grey   { background: #F5F5F5; color: #888; }
  .status-grey   .dot { background: #999; }
  .status-fail   { background: #FFEBEE; color: #B71C1C; }
  .status-fail   .dot { background: #B71C1C; }

  .no-data { padding: 24px; text-align: center; color: #aaa; font-size: 13px; border: 1px solid #eee; border-radius: 4px; }

  /* FOOTER */
  .footer { background: #fafafa; border-top: 1px solid #e6e6e6; padding: 12px 32px; display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: #999; }
  .footer-logo { color: #009530; font-weight: 600; }
</style>
</head>
<body>
<div class="card">

  <div class="header">
    <h1>Bug &amp; Defect Report</h1>
    <div class="meta">Schneider Electric &mdash; PICASso Project &mdash; {{ generated_date }}</div>
  </div>

  <div class="summary-strip">
    <div class="s-card sit"><div class="s-count">{{ sit_issues | length }}</div><div class="s-label">SIT Defects</div></div>
    <div class="s-card uat"><div class="s-count">{{ uat_issues | length }}</div><div class="s-label">UAT Bugs</div></div>
    <div class="s-card prod"><div class="s-count">{{ prod_issues | length }}</div><div class="s-label">Prod Defects</div></div>
  </div>

  {# ---- MACROS ---- #}

  {% macro pri_badge(p) %}
  {%- set pl = p | lower -%}
  {%- if pl == 'blocker'   -%}<span class="badge badge-blocker">{{ p }}</span>
  {%- elif pl == 'critical' -%}<span class="badge badge-critical">{{ p }}</span>
  {%- elif pl == 'high'    -%}<span class="badge badge-high">{{ p }}</span>
  {%- elif pl == 'medium'  -%}<span class="badge badge-medium">{{ p }}</span>
  {%- else -%}<span class="badge badge-low">{{ p }}</span>
  {%- endif -%}
  {% endmacro %}

  {% macro status_badge(s) %}
  {%- set sl = s | lower -%}
  {%- if 'failed' in sl -%}
    <span class="status-pill status-fail"><span class="dot"></span>{{ s }}</span>
  {%- elif 'progress' in sl or 'review' in sl or 'development' in sl -%}
    <span class="status-pill status-inprog"><span class="dot"></span>{{ s }}</span>
  {%- elif sl in ('open', 'to do', 'todo', 'reopened', 'new', 'assigned') -%}
    <span class="status-pill status-open"><span class="dot"></span>{{ s }}</span>
  {%- elif 'pending' in sl or 'on hold' in sl or 'change request' in sl -%}
    <span class="status-pill status-grey"><span class="dot"></span>{{ s }}</span>
  {%- else -%}
    <span class="status-pill status-closed"><span class="dot"></span>{{ s }}</span>
  {%- endif -%}
  {% endmacro %}

  {% macro issue_table(issues) %}
  {% if issues %}
  <table>
    <thead><tr>
      <th class="col-num">#</th>
      <th class="col-summary">Summary</th>
      <th class="col-type">Type</th>
      <th class="col-pri">Priority</th>
      <th class="col-status">Status</th>
      <th class="col-reporter">Reporter</th>
      <th class="col-date">Created</th>
    </tr></thead>
    <tbody>
      {% for issue in issues %}
      <tr>
        <td class="col-num">{{ loop.index }}</td>
        <td class="col-summary">{{ issue.summary }}</td>
        <td class="col-type">{{ issue.issue_type }}</td>
        <td class="col-pri">{{ pri_badge(issue.priority) }}</td>
        <td class="col-status">{{ status_badge(issue.status) }}</td>
        <td class="col-reporter">{{ issue.reporter or '&mdash;' }}</td>
        <td class="col-date">{{ issue.created or '&mdash;' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="no-data">No issues found for this period.</div>
  {% endif %}
  {% endmacro %}

  <!-- SECTION 1: SIT -->
  <div class="section sit">
    <div class="section-header">
      <h2>SIT Testing Defects</h2>
      <span class="sec-period">{{ sit_period }} &ndash; present</span>
      <span class="sec-count">{{ sit_issues | length }} issue{{ 's' if sit_issues | length != 1 else '' }}</span>
    </div>
    <div class="reporters-line">Reporters: <strong>{{ sit_reporters | join(' | ') }}</strong></div>
    {{ issue_table(sit_issues) }}
  </div>

  <!-- SECTION 2: UAT -->
  <div class="section uat">
    <div class="section-header">
      <h2>UAT Bugs</h2>
      <span class="sec-period">{{ uat_period }} &ndash; present</span>
      <span class="sec-count">{{ uat_issues | length }} issue{{ 's' if uat_issues | length != 1 else '' }}</span>
    </div>
    <div class="reporters-line">Reporters: <strong>{{ uat_reporters | join(' | ') }}</strong></div>
    {{ issue_table(uat_issues) }}
  </div>

  <!-- SECTION 3: Production -->
  <div class="section prod">
    <div class="section-header">
      <h2>Production Defects</h2>
      <span class="sec-period">{{ prod_period }} &ndash; present</span>
      <span class="sec-count">{{ prod_issues | length }} issue{{ 's' if prod_issues | length != 1 else '' }}</span>
    </div>
    <div class="reporters-line">Reporters: <strong>{{ prod_reporters | join(' | ') }}</strong></div>
    {{ issue_table(prod_issues) }}
  </div>

  <div class="footer">
    <span class="footer-logo">Schneider Electric &mdash; SE-DevTools</span>
    <span>Total: {{ (sit_issues | length) + (uat_issues | length) + (prod_issues | length) }} issue(s) // {{ generated_date }}</span>
  </div>

</div>
</body>
</html>
